{
    "editor.formatOnSave": true,
    "editor.detectIndentation": false,
    "[php]": {
        "editor.defaultFormatter": "open-southeners.laravel-pint"
    },
    "[vue]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[javascript]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[typescript]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "laravel-pint.enable": true,
}